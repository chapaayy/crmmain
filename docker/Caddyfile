{
	email {$CADDY_EMAIL}
}

https://{$CRM_DOMAIN} {
	encode zstd gzip
	@dynamic {
		not path /_next/static/* /favicon.ico /robots.txt /sitemap.xml
	}
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
	header @dynamic {
		Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
		Pragma "no-cache"
		Expires "0"
	}
	reverse_proxy frontend:{$FRONTEND_PORT}
}

https://{$API_DOMAIN} {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Cache-Control "no-store"
	}

	# Uploads are not served directly from the volume.
	# Protected API endpoints stream allowed files after JWT/RBAC checks.
	reverse_proxy backend:{$BACKEND_PORT}
}
