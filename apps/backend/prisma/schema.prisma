generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  SUPER_ADMIN
  ADMIN
  HR_MANAGER
  PAYROLL_MANAGER
  SALES_MANAGER
  WAREHOUSE_MANAGER
  ACCOUNTANT
  VIEWER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
  OTHER
}

enum WorkScheduleType {
  FIVE_TWO
  TWO_TWO
  SHIFT
  FLEXIBLE
  CUSTOM
}

enum WorkShiftStatus {
  PLANNED
  WORKED
  MISSED
  LATE
  SICK
  VACATION
  DAY_OFF
}

enum TimeEntrySource {
  MANUAL
  SYSTEM
  IMPORT
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum PayrollPeriodStatus {
  OPEN
  CALCULATED
  APPROVED
  PAID
  CLOSED
}

enum PayrollRunStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
  CANCELLED
}

enum PayrollAdjustmentType {
  BONUS
  PENALTY
  CORRECTION
}

enum CommissionSource {
  PAID_ORDERS
  COMPLETED_ORDERS
  PROFIT
}

enum CustomerStatus {
  LEAD
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum BagType {
  POLYPROPYLENE_BAG
  BIG_BAG
  LINER_BAG
  TRANSPARENT_BAG
  HANDLED_BAG
  CUSTOM_BAG
}

enum BagTopType {
  OPEN_TOP
  VALVE
  SKIRT
  DUFFLE
  CUSTOM
}

enum BagBottomType {
  FLAT
  BLOCK
  DISCHARGE_SPOUT
  CLOSED
  CUSTOM
}

enum OrderStatus {
  DRAFT
  NEW
  MANAGER_PROCESSING
  WAITING_PAYMENT
  PAID
  RESERVED
  PICKING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum DiscountType {
  NONE
  PERCENT
  FIXED
}

enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  OVERPAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  ONLINE
  OTHER
}

enum StockMovementType {
  RESERVATION
  RECEIPT
  SALE
  RELEASE_RESERVATION
  SHIPMENT
  RETURN
  ADJUSTMENT
  TRANSFER
  WRITEOFF
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskRelatedType {
  CUSTOMER
  LEAD
  ORDER
  PRODUCT
}

enum ResponsibilityStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ResponsibilityAssignmentRole {
  OWNER
  BACKUP
  PARTICIPANT
  VIEWER
}

enum ResponsibilityInstructionFormat {
  MARKDOWN
  PLAIN_TEXT
}

enum SecretVaultItemType {
  LOGIN_PASSWORD
  API_KEY
  TOKEN
  CARD_INFO
  EMAIL_ACCOUNT
  TELEGRAM_ACCOUNT
  HOSTING
  OTHER
}

enum SecretAccessAction {
  CREATED
  UPDATED
  DELETED
  REVEALED
  METADATA_VIEWED
}

enum DocumentType {
  INVOICE
  COMMERCIAL_OFFER
  DELIVERY_NOTE
  ACT
  CONTRACT
}

enum TimelineEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  COMMENTED
  FILE_UPLOADED
  PAYMENT_RECEIVED
  STOCK_MOVED
  TASK_COMPLETED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  EXPORT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  firstName    String?
  lastName     String?
  phone        String?
  locale       String    @default("ru")
  primaryRole  RoleCode  @default(VIEWER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdById  String?
  updatedById  String?
  createdBy    User?     @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?     @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  createdUsers            User[]               @relation("UserCreatedBy")
  updatedUsers            User[]               @relation("UserUpdatedBy")
  roles                   UserRole[]           @relation("UserRoleUser")
  assignedUserRoles       UserRole[]           @relation("UserRoleAssignedBy")
  createdRoles            Role[]               @relation("RoleCreatedBy")
  updatedRoles            Role[]               @relation("RoleUpdatedBy")
  createdPermissions      Permission[]         @relation("PermissionCreatedBy")
  updatedPermissions      Permission[]         @relation("PermissionUpdatedBy")
  createdRolePermissions  RolePermission[]     @relation("RolePermissionCreatedBy")
  refreshTokens           RefreshToken[]
  createdProductCategories ProductCategory[]    @relation("ProductCategoryCreatedBy")
  updatedProductCategories ProductCategory[]    @relation("ProductCategoryUpdatedBy")
  createdProducts         Product[]            @relation("ProductCreatedBy")
  updatedProducts         Product[]            @relation("ProductUpdatedBy")
  createdProductVariants  ProductVariant[]     @relation("ProductVariantCreatedBy")
  updatedProductVariants  ProductVariant[]     @relation("ProductVariantUpdatedBy")
  managedWarehouses       Warehouse[]          @relation("WarehouseManager")
  createdWarehouses       Warehouse[]          @relation("WarehouseCreatedBy")
  updatedWarehouses       Warehouse[]          @relation("WarehouseUpdatedBy")
  createdStockItems       StockItem[]          @relation("StockItemCreatedBy")
  updatedStockItems       StockItem[]          @relation("StockItemUpdatedBy")
  createdStockMovements   StockMovement[]      @relation("StockMovementCreatedBy")
  updatedStockMovements   StockMovement[]      @relation("StockMovementUpdatedBy")
  assignedTasks           Task[]               @relation("TaskAssignedTo")
  ownedResponsibilities   Responsibility[]     @relation("ResponsibilityOwnerUser")
  createdResponsibilities Responsibility[]     @relation("ResponsibilityCreatedBy")
  responsibilityAssignments ResponsibilityAssignment[] @relation("ResponsibilityAssignmentUser")
  assignedResponsibilities ResponsibilityAssignment[] @relation("ResponsibilityAssignmentAssignedBy")
  createdResponsibilityInstructions ResponsibilityInstruction[] @relation("ResponsibilityInstructionCreatedBy")
  updatedResponsibilityInstructions ResponsibilityInstruction[] @relation("ResponsibilityInstructionUpdatedBy")
  createdSecretVaultItems SecretVaultItem[]    @relation("SecretVaultItemCreatedBy")
  updatedSecretVaultItems SecretVaultItem[]    @relation("SecretVaultItemUpdatedBy")
  ownedSecretVaultItems   SecretVaultItem[]    @relation("SecretVaultItemOwnerUser")
  secretAccessLogs        SecretAccessLog[]    @relation("SecretAccessLogUser")
  createdTasks            Task[]               @relation("TaskCreatedBy")
  updatedTasks            Task[]               @relation("TaskUpdatedBy")
  comments                Comment[]            @relation("CommentAuthor")
  timelineEvents          TimelineEvent[]      @relation("TimelineEventActor")
  notifications           Notification[]
  auditLogs               AuditLog[]
  createdFileAssets       FileAsset[]          @relation("FileAssetCreatedBy")
  updatedFileAssets       FileAsset[]          @relation("FileAssetUpdatedBy")
  createdSettings         Setting[]            @relation("SettingCreatedBy")
  updatedSettings         Setting[]            @relation("SettingUpdatedBy")
  employeeProfile         EmployeeProfile?     @relation("EmployeeProfileUser")
  approvedTimeEntries     TimeEntry[]          @relation("TimeEntryApprovedBy")
  calculatedPayrollRuns   PayrollRun[]         @relation("PayrollRunCalculatedBy")
  approvedPayrollRuns     PayrollRun[]         @relation("PayrollRunApprovedBy")
  createdPayrollAdjustments PayrollAdjustment[] @relation("PayrollAdjustmentCreatedBy")

  @@index([primaryRole])
  @@index([locale])
  @@index([isActive])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
}

model Role {
  id          String           @id @default(cuid())
  code        RoleCode         @unique
  name        String           @unique
  color       String           @default("#22D3EE")
  description String?
  isSystem    Boolean          @default(false)
  createdById String?
  updatedById String?
  createdBy   User?            @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?            @relation("RoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  users       UserRole[]
  permissions RolePermission[]

  @@index([deletedAt])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  resource    String
  action      String
  description String?
  createdById String?
  updatedById String?
  createdBy   User?            @relation("PermissionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?            @relation("PermissionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  roles       RolePermission[]

  @@index([resource])
  @@index([action])
  @@index([deletedAt])
}

model UserRole {
  id           String    @id @default(cuid())
  userId       String
  roleId       String
  assignedById String?
  user         User      @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy   User?     @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
  @@index([deletedAt])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdById  String?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdBy    User?      @relation("RolePermissionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@index([createdById])
  @@index([deletedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([deletedAt])
}

model ProductCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  parentId    String?
  createdById String?
  updatedById String?
  parent      ProductCategory?  @relation("ProductCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[] @relation("ProductCategoryTree")
  createdBy   User?             @relation("ProductCategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?             @relation("ProductCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  products    Product[]
  variants    ProductVariant[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@index([parentId])
  @@index([deletedAt])
}

model Product {
  id                     String           @id @default(cuid())
  sku                    String           @unique
  name                   String
  categoryId             String
  description            String?
  size                   String?
  density                String?
  color                  String?
  material               String           @default("polypropylene")
  bagType                BagType          @default(POLYPROPYLENE_BAG)
  weight                 Decimal?         @db.Decimal(12, 3)
  capacity               String?
  hasLiner               Boolean          @default(false)
  hasHandles             Boolean          @default(false)
  topType                BagTopType?
  bottomType             BagBottomType?
  minOrderQty            Int              @default(1)
  packageQty             Int?
  purchasePrice          Decimal?         @db.Decimal(14, 2)
  retailPrice            Decimal?         @db.Decimal(14, 2)
  wholesalePrice         Decimal?         @db.Decimal(14, 2)
  isCustomOrderAvailable Boolean          @default(false)
  isActive               Boolean          @default(true)
  createdById            String?
  updatedById            String?
  category               ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy              User?            @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy              User?            @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  variants               ProductVariant[]
  stockItems             StockItem[]
  stockMovements         StockMovement[]
  tasks                  Task[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?

  @@index([categoryId])
  @@index([bagType])
  @@index([isActive])
  @@index([deletedAt])
}

model ProductVariant {
  id                     String          @id @default(cuid())
  productId              String
  sku                    String          @unique
  name                   String
  categoryId             String
  description            String?
  size                   String?
  density                String?
  color                  String?
  material               String          @default("polypropylene")
  bagType                BagType         @default(POLYPROPYLENE_BAG)
  weight                 Decimal?        @db.Decimal(12, 3)
  capacity               String?
  hasLiner               Boolean         @default(false)
  hasHandles             Boolean         @default(false)
  topType                BagTopType?
  bottomType             BagBottomType?
  minOrderQty            Int             @default(1)
  packageQty             Int?
  purchasePrice          Decimal?        @db.Decimal(14, 2)
  retailPrice            Decimal?        @db.Decimal(14, 2)
  wholesalePrice         Decimal?        @db.Decimal(14, 2)
  isCustomOrderAvailable Boolean         @default(false)
  isActive               Boolean         @default(true)
  createdById            String?
  updatedById            String?
  product                Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category               ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy              User?           @relation("ProductVariantCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy              User?           @relation("ProductVariantUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  stockItems             StockItem[]
  stockMovements         StockMovement[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?

  @@index([productId])
  @@index([categoryId])
  @@index([bagType])
  @@index([isActive])
  @@index([deletedAt])
}

model Warehouse {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  address        String?
  isActive       Boolean         @default(true)
  managerId      String?
  createdById    String?
  updatedById    String?
  manager        User?           @relation("WarehouseManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdBy      User?           @relation("WarehouseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?           @relation("WarehouseUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  stockItems     StockItem[]
  movements      StockMovement[] @relation("StockMovementWarehouse")
  outgoingMoves  StockMovement[] @relation("StockMovementFromWarehouse")
  incomingMoves  StockMovement[] @relation("StockMovementToWarehouse")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@index([managerId])
  @@index([isActive])
  @@index([deletedAt])
}

model StockItem {
  id               String          @id @default(cuid())
  warehouseId      String
  productId        String
  variantId        String?
  quantity         Decimal         @default(0) @db.Decimal(14, 3)
  reservedQuantity Decimal         @default(0) @db.Decimal(14, 3)
  unit             String          @default("pcs")
  createdById      String?
  updatedById      String?
  warehouse        Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdBy        User?           @relation("StockItemCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?           @relation("StockItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  movements        StockMovement[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  @@unique([warehouseId, productId, variantId])
  @@index([warehouseId])
  @@index([productId])
  @@index([variantId])
  @@index([deletedAt])
}

model StockMovement {
  id              String             @id @default(cuid())
  type            StockMovementType
  warehouseId     String
  fromWarehouseId String?
  toWarehouseId   String?
  stockItemId     String?
  productId       String
  variantId       String?
  quantity        Decimal            @db.Decimal(14, 3)
  unit            String             @default("pcs")
  balanceBefore   Decimal?           @db.Decimal(14, 3)
  balanceAfter    Decimal?           @db.Decimal(14, 3)
  reference       String?
  note            String?
  createdById     String?
  updatedById     String?
  warehouse       Warehouse          @relation("StockMovementWarehouse", fields: [warehouseId], references: [id], onDelete: Restrict)
  fromWarehouse   Warehouse?         @relation("StockMovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse     Warehouse?         @relation("StockMovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  stockItem       StockItem?         @relation(fields: [stockItemId], references: [id], onDelete: SetNull)
  product         Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant         ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdBy       User?              @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?              @relation("StockMovementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([type])
  @@index([warehouseId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([stockItemId])
  @@index([productId])
  @@index([variantId])
  @@index([type, createdAt])
  @@index([deletedAt])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  dueAt        DateTime?    @map("dueDate")
  dueSoonNotifiedAt DateTime?
  relatedType  TaskRelatedType?
  relatedId    String?
  isEmployeeTask Boolean    @default(false)
  completedAt  DateTime?
  assignedToId String?
  productId    String?
  assigneeEmployeeId String?
  assigneeDepartment String?
  responsibilityId String?
  createdById  String?
  updatedById  String?
  assignedTo   User?        @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  assigneeEmployee EmployeeProfile? @relation("TaskAssigneeEmployee", fields: [assigneeEmployeeId], references: [id], onDelete: SetNull)
  responsibility Responsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  product      Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("TaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  comments     Comment[]
  events       TimelineEvent[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([assigneeEmployeeId])
  @@index([assigneeDepartment])
  @@index([responsibilityId])
  @@index([createdById])
  @@index([relatedType, relatedId])
  @@index([isEmployeeTask])
  @@index([isEmployeeTask, assignedToId, status, dueAt])
  @@index([isEmployeeTask, assigneeEmployeeId, status, dueAt])
  @@index([productId])
  @@index([dueAt])
  @@index([dueSoonNotifiedAt])
  @@index([deletedAt])
}

model Comment {
  id         String    @id @default(cuid())
  body       String
  authorId   String
  taskId     String?
  author     User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@index([authorId])
  @@index([taskId])
  @@index([deletedAt])
}

model TimelineEvent {
  id          String            @id @default(cuid())
  type        TimelineEventType
  title       String
  description String?
  payload     Json?
  occurredAt  DateTime          @default(now())
  actorId     String?
  taskId      String?
  actor       User?             @relation("TimelineEventActor", fields: [actorId], references: [id], onDelete: SetNull)
  task        Task?             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@index([type])
  @@index([actorId])
  @@index([taskId])
  @@index([occurredAt])
  @@index([deletedAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([userId, readAt, deletedAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  deletedAt  DateTime?

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([deletedAt])
}

model EmployeeProfile {
  id              String         @id @default(cuid())
  userId          String         @unique
  employeeNumber  String         @unique
  firstName       String
  lastName        String
  middleName      String?
  phone           String?
  email           String?
  position        String?
  department      String?
  employmentType  EmploymentType @default(FULL_TIME)
  hireDate        DateTime?
  fireDate        DateTime?
  baseSalary      Decimal?       @db.Decimal(14, 2)
  hourlyRate      Decimal?       @db.Decimal(14, 2)
  shiftRate       Decimal?       @db.Decimal(14, 2)
  commissionRate  Decimal?       @db.Decimal(5, 2)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  user            User           @relation("EmployeeProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  schedules       WorkSchedule[]
  shifts          WorkShift[]
  timeEntries     TimeEntry[]
  payrollLines    PayrollLine[]
  adjustments     PayrollAdjustment[]
  assignedTasks    Task[] @relation("TaskAssigneeEmployee")
  ownedResponsibilities Responsibility[] @relation("ResponsibilityOwnerEmployee")
  responsibilityAssignments ResponsibilityAssignment[]
  ownedSecretVaultItems SecretVaultItem[] @relation("SecretVaultItemOwnerEmployee")

  @@index([userId])
  @@index([employeeNumber])
  @@index([department])
  @@index([position])
  @@index([employmentType])
  @@index([isActive])
  @@index([deletedAt])
}

model WorkSchedule {
  id           String           @id @default(cuid())
  employeeId   String
  name         String
  type         WorkScheduleType @default(FIVE_TWO)
  workdayHours Decimal          @default(8) @db.Decimal(5, 2)
  startsAt     DateTime?
  endsAt       DateTime?
  timezone     String           @default("Europe/Berlin")
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  employee     EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shifts       WorkShift[]

  @@index([employeeId])
  @@index([type])
  @@index([isActive])
  @@index([employeeId, deletedAt, isActive])
  @@index([deletedAt])
}

model WorkShift {
  id           String          @id @default(cuid())
  employeeId   String
  scheduleId   String?
  date         DateTime
  plannedStart DateTime?
  plannedEnd   DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?
  status       WorkShiftStatus @default(PLANNED)
  comment      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  employee     EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  schedule     WorkSchedule?   @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([scheduleId])
  @@index([date])
  @@index([status])
  @@index([employeeId, date, deletedAt])
  @@index([deletedAt])
}

model TimeEntry {
  id            String          @id @default(cuid())
  employeeId    String
  date          DateTime
  startedAt     DateTime
  endedAt       DateTime?
  breakMinutes  Int             @default(0)
  totalMinutes  Int             @default(0)
  source        TimeEntrySource @default(MANUAL)
  approvedById  String?
  approvedAt    DateTime?
  status        TimeEntryStatus @default(DRAFT)
  comment       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy    User?           @relation("TimeEntryApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([approvedById])
  @@index([date])
  @@index([status])
  @@index([date, status])
  @@index([employeeId, date, status])
  @@index([employeeId, date, deletedAt])
  @@index([deletedAt])
}

model PayrollPeriod {
  id          String              @id @default(cuid())
  name        String
  dateFrom    DateTime
  dateTo      DateTime
  status      PayrollPeriodStatus @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  runs        PayrollRun[]
  adjustments PayrollAdjustment[]

  @@index([dateFrom])
  @@index([dateTo])
  @@index([status])
  @@index([deletedAt])
}

model PayrollRun {
  id               String           @id @default(cuid())
  periodId         String
  calculatedById   String?
  approvedById     String?
  calculatedAt     DateTime?
  approvedAt       DateTime?
  status           PayrollRunStatus @default(DRAFT)
  totalGross       Decimal          @default(0) @db.Decimal(14, 2)
  totalBonuses     Decimal          @default(0) @db.Decimal(14, 2)
  totalPenalties   Decimal          @default(0) @db.Decimal(14, 2)
  totalCommissions Decimal          @default(0) @db.Decimal(14, 2)
  totalNet         Decimal          @default(0) @db.Decimal(14, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  period           PayrollPeriod    @relation(fields: [periodId], references: [id], onDelete: Cascade)
  calculatedBy     User?            @relation("PayrollRunCalculatedBy", fields: [calculatedById], references: [id], onDelete: SetNull)
  approvedBy       User?            @relation("PayrollRunApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lines            PayrollLine[]

  @@index([periodId])
  @@index([calculatedById])
  @@index([approvedById])
  @@index([status])
  @@index([periodId, status])
  @@index([deletedAt])
}

model PayrollLine {
  id                String          @id @default(cuid())
  payrollRunId      String
  employeeId        String
  baseSalaryAmount  Decimal         @default(0) @db.Decimal(14, 2)
  hourlyAmount      Decimal         @default(0) @db.Decimal(14, 2)
  shiftAmount       Decimal         @default(0) @db.Decimal(14, 2)
  overtimeAmount    Decimal         @default(0) @db.Decimal(14, 2)
  bonusAmount       Decimal         @default(0) @db.Decimal(14, 2)
  penaltyAmount     Decimal         @default(0) @db.Decimal(14, 2)
  commissionAmount  Decimal         @default(0) @db.Decimal(14, 2)
  grossAmount       Decimal         @default(0) @db.Decimal(14, 2)
  netAmount         Decimal         @default(0) @db.Decimal(14, 2)
  workedHours       Decimal         @default(0) @db.Decimal(10, 2)
  workedDays        Decimal         @default(0) @db.Decimal(10, 2)
  overtimeHours     Decimal         @default(0) @db.Decimal(10, 2)
  comment           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  payrollRun        PayrollRun      @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee          EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([payrollRunId, deletedAt])
  @@index([deletedAt])
}

model PayrollAdjustment {
  id          String                @id @default(cuid())
  employeeId  String
  periodId    String
  type        PayrollAdjustmentType
  amount      Decimal               @db.Decimal(14, 2)
  reason      String
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  employee    EmployeeProfile       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  period      PayrollPeriod         @relation(fields: [periodId], references: [id], onDelete: Cascade)
  createdBy   User                  @relation("PayrollAdjustmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([employeeId])
  @@index([periodId])
  @@index([type])
  @@index([createdById])
  @@index([deletedAt])
}

model Responsibility {
  id              String                       @id @default(cuid())
  title           String
  description     String?
  category        String?
  status          ResponsibilityStatus         @default(ACTIVE)
  ownerUserId     String?
  ownerEmployeeId String?
  createdById     String
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  deletedAt       DateTime?
  ownerUser       User?                        @relation("ResponsibilityOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerEmployee   EmployeeProfile?             @relation("ResponsibilityOwnerEmployee", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  createdBy       User                         @relation("ResponsibilityCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignments     ResponsibilityAssignment[]
  instructions    ResponsibilityInstruction[]
  checklistItems  ResponsibilityChecklistItem[]
  secrets         SecretVaultItem[]
  tasks           Task[]

  @@index([ownerUserId])
  @@index([ownerEmployeeId])
  @@index([createdById])
  @@index([category])
  @@index([status])
  @@index([deletedAt])
}

model ResponsibilityAssignment {
  id               String                       @id @default(cuid())
  responsibilityId String
  employeeId       String?
  userId           String?
  role             ResponsibilityAssignmentRole @default(PARTICIPANT)
  assignedById     String
  assignedAt       DateTime                     @default(now())
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  responsibility   Responsibility               @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)
  employee         EmployeeProfile?             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  user             User?                        @relation("ResponsibilityAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy       User                         @relation("ResponsibilityAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@index([responsibilityId])
  @@index([employeeId])
  @@index([userId])
  @@index([role])
  @@index([assignedById])
  @@index([employeeId, responsibilityId])
  @@index([userId, responsibilityId])
}

model ResponsibilityInstruction {
  id               String                          @id @default(cuid())
  responsibilityId String
  title            String
  content          String
  format           ResponsibilityInstructionFormat @default(MARKDOWN)
  version          Int                             @default(1)
  isActive         Boolean                         @default(true)
  createdById      String
  updatedById      String?
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt
  responsibility   Responsibility                  @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)
  createdBy        User                            @relation("ResponsibilityInstructionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User?                           @relation("ResponsibilityInstructionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([responsibilityId])
  @@index([isActive])
  @@index([createdById])
  @@index([updatedById])
}

model ResponsibilityChecklistItem {
  id               String         @id @default(cuid())
  responsibilityId String
  title            String
  description      String?
  sortOrder        Int            @default(0)
  isRequired       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  responsibility   Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  @@index([responsibilityId])
  @@index([sortOrder])
}

model SecretVaultItem {
  id               String              @id @default(cuid())
  title            String
  description      String?
  type             SecretVaultItemType @default(OTHER)
  url              String?
  username         String?
  login            String?
  phone            String?
  email            String?
  encryptedSecret  String?
  encryptedNotes   String?
  responsibilityId String?
  ownerUserId      String?
  ownerEmployeeId  String?
  createdById      String
  updatedById      String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  responsibility   Responsibility?     @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  ownerUser        User?               @relation("SecretVaultItemOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerEmployee    EmployeeProfile?    @relation("SecretVaultItemOwnerEmployee", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  createdBy        User                @relation("SecretVaultItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User?               @relation("SecretVaultItemUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  accessLogs       SecretAccessLog[]

  @@index([responsibilityId])
  @@index([ownerUserId])
  @@index([ownerEmployeeId])
  @@index([createdById])
  @@index([updatedById])
  @@index([type])
  @@index([responsibilityId, deletedAt])
  @@index([ownerUserId, deletedAt])
  @@index([ownerEmployeeId, deletedAt])
  @@index([deletedAt])
}

model SecretAccessLog {
  id        String             @id @default(cuid())
  secretId  String
  userId    String
  action    SecretAccessAction
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())
  secret    SecretVaultItem     @relation(fields: [secretId], references: [id], onDelete: Cascade)
  user      User                @relation("SecretAccessLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([secretId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model FileAsset {
  id           String     @id @default(cuid())
  key          String     @unique
  originalName String
  mimeType     String
  size         Int
  path         String
  url          String?
  checksum     String?
  metadata     Json?
  createdById  String?
  updatedById  String?
  createdBy    User?      @relation("FileAssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?      @relation("FileAssetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@index([mimeType])
  @@index([createdById])
  @@index([deletedAt])
}

model Setting {
  id          String    @id @default(cuid())
  namespace   String    @default("global")
  key         String
  value       Json
  description String?
  isPublic    Boolean   @default(false)
  createdById String?
  updatedById String?
  createdBy   User?     @relation("SettingCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?     @relation("SettingUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([namespace, key])
  @@index([isPublic])
  @@index([deletedAt])
}
