COMPOSE_PROJECT_NAME=polybags-crm
APP_VERSION=latest
BACKEND_IMAGE=polybags-crm-backend
FRONTEND_IMAGE=polybags-crm-frontend
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# Public domains routed by Caddy.
CRM_DOMAIN=crm.com
API_DOMAIN=api.crm.com

# Host ports for Caddy.
HTTP_PORT=80
HTTPS_PORT=443
CADDY_EMAIL=admin@crm.com

# PostgreSQL.
POSTGRES_USER=crm_app
POSTGRES_PASSWORD=replace-me-postgres-password
POSTGRES_DB=crm_polybags
DATABASE_URL=postgresql://crm_app:replace-me-postgres-password@postgres:5432/crm_polybags?schema=public

# Redis.
REDIS_URL=redis://redis:6379

# Backend.
BACKEND_PORT=3001
NODE_ENV=production
API_PUBLIC_URL=https://api.crm.com
CORS_ORIGINS=https://crm.com
JWT_ACCESS_SECRET=replace-me-access-token-secret
JWT_REFRESH_SECRET=replace-me-refresh-token-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REFRESH_COOKIE_NAME=refreshToken
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=lax
UPLOADS_DIR=/app/uploads

# HR / attendance / payroll.
PAYROLL_CURRENCY=RUB
PAYROLL_TIMEZONE=Europe/Berlin
PAYROLL_DEFAULT_WORKDAY_HOURS=8
PAYROLL_OVERTIME_MULTIPLIER=1.5
PAYROLL_ENABLE_SALES_COMMISSION=true
PAYROLL_ENABLE_ATTENDANCE=true

# Secure secrets vault.
SECRETS_ENCRYPTION_KEY=change_me_32_plus_chars_secret_key
SECRETS_ENABLE_REVEAL_AUDIT=true
SECRETS_REQUIRE_REASON_ON_REVEAL=true
SECRETS_MASK_BY_DEFAULT=true

# Optional company profile/requisites used as PDF fallbacks when Settings are empty.
COMPANY_NAME=Demo Polybags LLC
COMPANY_SHORT_NAME=Demo Polybags
COMPANY_PHONE=+1-555-0100
COMPANY_EMAIL=info@example.com
COMPANY_WEBSITE=https://crm.com
COMPANY_ADDRESS=Company address placeholder
COMPANY_INN=0000000000
COMPANY_KPP=000000000
COMPANY_OGRN=0000000000000
COMPANY_BANK_NAME=Bank placeholder
COMPANY_BIK=000000000
COMPANY_ACCOUNT=00000000000000000000
COMPANY_CORRESPONDENT_ACCOUNT=00000000000000000000

# Initial super admin used by `npm run prisma:seed`.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-me-super-admin-password
SUPER_ADMIN_NAME=System Admin

# Backups.
BACKUP_RETENTION_DAYS=14

# Frontend.
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CRM_URL=https://crm.com
